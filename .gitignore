# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# database backups
backups/*
!backups/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# docs (except PLANS and LOGS)
docs/*
!docs/PLANS/
!docs/LOGS/

# MCP configuration (personal)
.mcp.json

# Playwright MCP screenshots
.playwright-mcp/
# Authentication and tests
auth.json
test-results/

# Tool specific
.claude/
