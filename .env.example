# ===========================================
# altee-core 環境変数テンプレート
# このファイルを .env.local にコピーして値を設定してください
# ===========================================

# Database Configuration (Docker Compose)
DATABASE_URL="postgresql://postgres:password@localhost:5433/altee_dev?schema=public"

# OAuth設定
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# 管理者メールアドレス（カンマ区切りで複数指定可能）
ADMIN_EMAILS=your_email@example.com

# Cloudflare R2 Object Storage
STORAGE_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your_r2_access_key
STORAGE_SECRET_KEY=your_r2_secret_key
STORAGE_BUCKET=altee-images
STORAGE_REGION=auto
STORAGE_FORCE_PATH_STYLE=false

# 画像配信URL
NEXT_PUBLIC_STORAGE_URL=https://cdn.altee.me

# Twitch API Configuration (optional)
# Get these from https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_ID=your_twitch_client_id
# TWITCH_CLIENT_SECRET=your_twitch_client_secret
# TWITCH_WEBHOOK_SECRET=your_webhook_secret

# Domain for public URLs
NEXT_PUBLIC_DOMAIN=localhost

# Maintenance Mode
# MAINTENANCE_MODE=true
# MAINTENANCE_BYPASS_SECRET=your_random_secret_here