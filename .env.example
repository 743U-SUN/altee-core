# Database Configuration
# Development (Docker Compose)
DATABASE_URL="postgresql://postgres:password@localhost:5432/altee_dev?schema=public"

# Production (Docker Compose) - Override in .env.production
# DATABASE_URL="postgresql://postgres:your_strong_password@db:5432/altee_prod?schema=public"

# PostgreSQL Configuration for Production
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=altee_prod

# Next.js Configuration
NODE_ENV=development
NEXT_TELEMETRY_DISABLED=1

# Add other environment variables here as needed
# NEXTAUTH_SECRET=your_nextauth_secret
# NEXTAUTH_URL=http://localhost:3000

# Twitch API Configuration
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_WEBHOOK_SECRET=your_webhook_secret

# Domain for public URLs (used in Twitch embeds and webhooks)
NEXT_PUBLIC_DOMAIN=localhost